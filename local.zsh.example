# Machine-local config. Copy to local.zsh (git-ignored) and adapt per machine.
# Keep machine-specific paths and CORP-INTERNAL urls here, NOT in the repo.

# COLORTERM is universal enough to keep in the repo, but tool hooks below
# differ per machine and error out if the tool isn't installed.

# --- direnv ---
# command -v direnv >/dev/null && eval "$(direnv hook zsh)"

# --- Volta (node) ---
# export VOLTA_HOME="$HOME/.volta"
# export PATH="$VOLTA_HOME/bin:$PATH"

# --- nvm ---
# export NVM_DIR="$HOME/.nvm"
# [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
# [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"

# --- Rust / cargo (point at your internal mirror if you have one) ---
# export RUSTUP_DIST_SERVER=https://your-internal-mirror.example.com/rustup
# export RUSTUP_UPDATE_ROOT=https://your-internal-mirror.example.com/rustup/rustup
# [[ -r "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# --- misc PATH ---
# export PATH="$HOME/.local/bin:$PATH"

# --- prompt glyphs ---
# No Nerd Font? Switch the prompt to plain-Unicode glyphs (renders in any font):
# export PROMPT_KRONUZ_NERD_FONT=0
# Retune a single glyph (either mode); '' hides it. Names: os branch tag commit
# remote action clean dirty stashed ahead behind staged modified conflicted
# untracked venv vim emacs jobs duration ssh container dot return overwrite caret
# caret_alt.
# export PROMPT_KRONUZ_GLYPH_MODIFIED='*'
# export PROMPT_KRONUZ_GLYPH_OS=''        # hide the OS logo by the hostname

# --- prompt behavior ---
# Show the last command's duration once it exceeds this many seconds (default 3):
# export PROMPT_KRONUZ_CMD_DURATION_MIN=5
# Transient prompt: past prompts collapse to this caret. Set to '' to disable.
# export PROMPT_KRONUZ_TRANSIENT=''
# How the just-run command is restyled in the collapsed line: dim (default; same
# syntax colors, darker), mute (grey), or keep (leave the colors).
# export PROMPT_KRONUZ_TRANSIENT_STYLE=mute
# dim darkness (0=black .. 1=unchanged); mute color (a region_highlight spec):
# export PROMPT_KRONUZ_TRANSIENT_DIM=0.4
# export PROMPT_KRONUZ_TRANSIENT_HL='fg=242'

# --- external tool tweaks (see integrations/init.zsh; all auto-enabled when present) ---
# ripgrep: point at a config file for your default flags (smart-case, hidden, ...)
# export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"
# fzf: override the look/behavior of the pickers
# export FZF_DEFAULT_OPTS='--height 60% --layout=reverse --border --info=inline'
