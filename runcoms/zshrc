# kronuzsh: a lean, prezto-free zsh setup.
# Interactive entry point. Symlinked from ~/.zshrc -> runcoms/zshrc.
#
# Author: Germán Méndez Bravo (Kronuz) <german.mb@gmail.com>

# Resolve the repo root. This file lives in runcoms/, so climb out twice (:h:h),
# resolving symlinks first (:A) since ~/.zshrc is a symlink to here.
KRONUZSH="${KRONUZSH:-${${(%):-%x}:A:h:h}}"
export KRONUZSH

source "$KRONUZSH/runcoms/zshenv"   # also sourced by ~/.zshenv; harmless to repeat
source "$KRONUZSH/options.zsh"
source "$KRONUZSH/history.zsh"
source "$KRONUZSH/completion.zsh"
source "$KRONUZSH/keybindings.zsh"
source "$KRONUZSH/aliases.zsh"
source "$KRONUZSH/terminal.zsh"
source "$KRONUZSH/plugins.zsh"
source "$KRONUZSH/integrations/init.zsh"   # optional external tools (fzf, zoxide, ...), each guarded
source "$KRONUZSH/prompt.zsh"
prompt_kronuz_setup
# The prompt's segments are deferred ${(e)...} strings; PROMPT_SUBST is what makes
# zsh expand them at display. (prezto's prompt module used to apply this from
# $prompt_opts; we set it explicitly since there's no module.) Set globally here,
# not inside prompt_kronuz_setup, which uses LOCAL_OPTIONS and would revert it.
setopt PROMPT_SUBST PROMPT_PERCENT PROMPT_CR PROMPT_SP

# Machine-local, non-public config (tool hooks, corp URLs, PROMPT_KRONUZ_* overrides).
# Tracked example: zshrc.local.example. The real ~/.zshrc.local is yours, in $HOME.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# An absent optional file above leaves $? = 1 (the failed `[[ -r ]]` test), which
# the prompt would show as a bogus error on the very first prompt. End clean.
true
